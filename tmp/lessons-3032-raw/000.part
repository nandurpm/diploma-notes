<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="description" content="Complete diploma handbook for DC Machines & Traction Motors, course 3032.">
<title>DC Machines & Traction Motors | Course 3032</title>
<style>
:root{
  --bg:#edf3f8;--paper:#fff;--ink:#102033;--muted:#566779;--line:#cedbe7;
  --nav:#071a2d;--blue:#0b5f9e;--cyan:#07889b;--teal:#0f766e;--copper:#b65f2b;
  --amber:#d97706;--red:#b4233c;--violet:#6d43b5;--green:#27835f;
  --soft:#f7fbff;--shadow:0 14px 36px rgba(15,23,42,.09);
  --mal:"Noto Sans Malayalam","Nirmala UI","Manjari","Segoe UI",sans-serif;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;width:100%;overflow-x:hidden;color:var(--ink);font-family:Inter,"Segoe UI",Arial,sans-serif;line-height:1.62;background:
 radial-gradient(circle at 0 0,rgba(8,136,155,.12),transparent 32rem),
 radial-gradient(circle at 100% 0,rgba(182,95,43,.10),transparent 34rem),
 linear-gradient(180deg,#f9fcff 0%,var(--bg) 100%)}
body:before{content:"";position:fixed;inset:0;z-index:-1;pointer-events:none;background:
 linear-gradient(rgba(11,95,158,.032) 1px,transparent 1px),
 linear-gradient(90deg,rgba(11,95,158,.032) 1px,transparent 1px);background-size:30px 30px}
a{color:var(--blue)}
button,input{font:inherit}
button{cursor:pointer}
.progress{position:fixed;top:0;left:0;width:0;height:4px;background:linear-gradient(90deg,#06b6d4,#0b5f9e,#b65f2b);z-index:500}
.topbar{position:sticky;top:0;z-index:420;background:rgba(7,26,45,.97);border-bottom:1px solid rgba(255,255,255,.14);box-shadow:0 8px 28px rgba(2,6,23,.24)}
.topbar-inner{width:100%;max-width:none;margin:0;padding:.48rem clamp(8px,1vw,18px);display:flex;align-items:center;gap:.45rem;min-height:64px}
.brand{display:flex;align-items:center;gap:.6rem;color:#fff;min-width:260px}
.brand-mark{width:48px;height:48px;display:grid;place-items:center;border-radius:15px;background:linear-gradient(135deg,#07889b,#b65f2b);font-weight:950;box-shadow:0 8px 22px rgba(0,0,0,.22)}
.brand-title{font-weight:950;line-height:1.05}
.brand-title small{display:block;color:#abc3d7;font-size:.72rem;margin-top:.18rem}
.top-actions{display:flex;align-items:center;gap:.38rem;flex:1;min-width:0}
.top-actions a,.top-actions button{border:1px solid rgba(255,255,255,.18);border-radius:999px;background:#102c47;color:#eef8ff;padding:.5rem .65rem;font-size:.74rem;font-weight:850;white-space:nowrap;text-decoration:none}
.top-actions a:hover,.top-actions button:hover,.top-actions a:focus-visible,.top-actions button:focus-visible{background:#17476f;outline:2px solid #67e8f9;outline-offset:1px}
.search{flex:1 1 220px;min-width:170px;max-width:360px}
.search input{width:100%;border:0;border-radius:999px;padding:.54rem .78rem;color:#0f172a}
.pdf{background:linear-gradient(135deg,#0b5f9e,#0f766e)!important;border:0!important}
.menu-btn{display:none!important}
.page-shell{width:100%;max-width:none;margin:0;overflow-x:clip;padding-inline:clamp(12px,1.4vw,24px);padding-block:clamp(10px,1vw,18px)}
.app-grid{width:100%;max-width:none;margin:0;overflow-x:clip;display:grid;grid-template-columns:minmax(220px,15vw) minmax(0,1fr) minmax(230px,17vw);gap:clamp(10px,1vw,18px);align-items:start}
.left-rail,.right-rail{position:sticky;top:78px;max-height:calc(100vh - 92px);overflow:auto;background:rgba(255,255,255,.96);border:1px solid var(--line);border-radius:20px;padding:.78rem;box-shadow:var(--shadow)}
.left-rail h2,.right-rail h2{font-size:.95rem;margin:.15rem 0 .55rem;color:#123d62}
.left-rail a{display:block;padding:.47rem .55rem;border-radius:10px;color:#26445f;text-decoration:none;font-size:.83rem;font-weight:780}
.left-rail a:hover,.left-rail a:focus-visible{background:#e9f5ff;color:#074f87}
.rail-group{border-top:1px solid var(--line);padding-top:.5rem;margin-top:.5rem}
.quick-card{border:1px solid var(--line);border-radius:14px;padding:.65rem;background:#f8fbff;margin:.48rem 0}
.quick-card b{display:block;color:#0b5f9e}
.main-content{width:100%;max-width:none;min-width:0;margin:0;overflow-x:clip}
.hero,.section{background:rgba(255,255,255,.97);border:1px solid var(--line);border-radius:24px;box-shadow:var(--shadow)}
.hero{min-height:calc(100vh - 102px);display:grid;grid-template-columns:minmax(0,1.2fr) minmax(360px,.8fr);gap:clamp(12px,1.2vw,22px);padding:clamp(1rem,2.3vw,2.5rem);overflow:hidden;position:relative}
.hero:after{content:"N Φ Iₐ Eᵍ T";position:absolute;right:-1.2rem;bottom:-2.2rem;font-weight:950;font-size:clamp(4rem,9vw,10rem);color:rgba(11,95,158,.045);transform:rotate(-8deg);white-space:nowrap}
.hero>*{position:relative;z-index:1}
.hero-copy{display:flex;flex-direction:column;justify-content:center}
.eyebrow{display:inline-flex;width:max-content;max-width:100%;padding:.3rem .6rem;border-radius:999px;background:#e4f4ff;color:#0c527f;font-size:.76rem;font-weight:950;text-transform:uppercase;letter-spacing:.045em}
h1,h2,h3,h4{line-height:1.16;letter-spacing:-.025em;color:#0d2238}
h1{font-size:clamp(2.5rem,4.7vw,5.6rem);margin:.6rem 0 .6rem}
h2{font-size:clamp(1.65rem,2.5vw,3rem);margin:.2rem 0 .65rem}
h3{font-size:clamp(1.16rem,1.45vw,1.55rem);margin:.85rem 0 .35rem}
h4{font-size:1.02rem;margin:.7rem 0 .25rem}
p{margin:.35rem 0 .72rem}
.lead{max-width:95ch;color:var(--muted);font-size:clamp(1.04rem,1.25vw,1.3rem)}
.hero-actions{display:flex;flex-wrap:wrap;gap:.55rem;margin-top:.9rem}
.action{border:0;border-radius:999px;padding:.72rem 1rem;font-weight:900;text-decoration:none;display:inline-flex;align-items:center;justify-content:center}
.primary{background:linear-gradient(135deg,#0b5f9e,#6d43b5);color:#fff}
.secondary{background:#eef7ff;color:#0b4e7a;border:1px solid #b9d7ed}
.meta-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:.6rem;margin-top:1rem}
.meta-grid div{border:1px solid var(--line);border-radius:15px;padding:.68rem;background:linear-gradient(180deg,#fff,#f7fbff)}
.meta-grid span{display:block;color:var(--muted);font-size:.68rem;font-weight:900;text-transform:uppercase}
.hero-visual{border-radius:22px;padding:1rem;color:#eaf7ff;background:
 radial-gradient(circle at 20% 18%,rgba(34,211,238,.22),transparent 18rem),
 radial-gradient(circle at 85% 80%,rgba(182,95,43,.34),transparent 20rem),
 linear-gradient(135deg,#071a2d,#0b3c61 62%,#154e55);display:grid;align-content:center;overflow:hidden}
.hero-visual h2,.hero-visual h3{color:#fff}
.module-map{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:.62rem;margin-top:.75rem}
.module-tile{border:1px solid rgba(255,255,255,.18);border-radius:16px;padding:.72rem;background:rgba(255,255,255,.08)}
.module-tile b{display:block;color:#67e8f9}
.rotor-wrap{display:grid;place-items:center;margin:.5rem 0}
.rotor{width:min(340px,78%);aspect-ratio:1;border-radius:50%;border:14px solid rgba(255,255,255,.18);position:relative;animation:spin 8s linear infinite}
.rotor:before,.rotor:after{content:"";position:absolute;inset:17%;border-radius:50%;border:9px solid rgba(103,232,249,.55)}
.rotor:after{inset:41% -10%;border-radius:999px;border:8px solid #f59e0b;transform:rotate(25deg)}
.rotor.paused{animation-play-state:paused}
@keyframes spin{to{transform:rotate(360deg)}}
.section{margin:.78rem 0;padding:clamp(.95rem,1.35vw,1.55rem);scroll-margin-top:84px}
.section-head{border-bottom:1px solid var(--line);padding-bottom:.7rem;margin-bottom:.8rem}
.section-head p{color:var(--muted);max-width:125ch}
.module{break-inside:auto}
.module-banner{border-radius:20px;padding:clamp(1rem,1.7vw,1.6rem);color:#fff;background:linear-gradient(135deg,#0d2238,var(--accent,#0b5f9e));margin-bottom:.8rem}
.module-banner h2,.module-banner h3{color:#fff}
.module-banner p{color:rgba(255,255,255,.88)}
.grid{display:grid;grid-template-columns:repeat(12,minmax(0,1fr));gap:.72rem}
.card{min-width:0;grid-column:span 6;border:1px solid var(--line);border-radius:18px;padding:.86rem;background:#fff;box-shadow:0 7px 18px rgba(15,23,42,.04);break-inside:avoid}
.third{grid-column:s